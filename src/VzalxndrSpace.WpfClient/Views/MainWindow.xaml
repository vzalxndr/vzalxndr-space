<Window x:Class="VzalxndrSpace.WpfClient.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VzalxndrSpace.WpfClient.Views"
        xmlns:converters="clr-namespace:VzalxndrSpace.WpfClient.Converters"
        mc:Ignorable="d"
        Title="vzalxndr-space: admin"
        Height="550"
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#191919"
        FontFamily="Segoe UI"
        TextElement.Foreground="#E0E0E0"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Твои конвертеры -->
        <converters:StatusToTextConverter x:Key="StatusTextConverter" />
        <converters:StatusToColorConverter x:Key="StatusColorConverter" />

        <!-- Шрифты для красивых иконок (встроены в Windows) -->
        <FontFamily x:Key="IconFont">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

        <!-- Стили для главных кнопок (Primary) -->
        <Style x:Key="PrimaryButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#2EA043" />
            <Setter Property="Foreground"
                    Value="#FFFFFF" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Padding"
                    Value="16,8" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#3FB950" />
                </Trigger>
                <Trigger Property="IsPressed"
                         Value="True">
                    <Setter Property="Background"
                            Value="#238636" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стили для кнопки выхода (Danger) -->
        <Style x:Key="DangerButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background"
                    Value="#33FF4C4C" />
            <!-- Полупрозрачный красный -->
            <Setter Property="Foreground"
                    Value="#FF6B6B" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#FF4C4C" />
                    <Setter Property="Foreground"
                            Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стили для кнопок управления внутри карточки (Иконки) -->
        <Style x:Key="IconButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="#808080" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="FontFamily"
                    Value="{StaticResource IconFont}" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="Width"
                    Value="32" />
            <Setter Property="Height"
                    Value="32" />
            <Setter Property="Margin"
                    Value="4,0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#2A2A2A" />
                    <Setter Property="Foreground"
                            Value="#FFFFFF" />
                </Trigger>
                <!-- Особый ховер для кнопки удаления -->
                <Trigger Property="ToolTip"
                         Value="Delete goal">
                    <Setter Property="Foreground"
                            Value="#808080" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver"
                                   Value="True" />
                        <Condition Property="ToolTip"
                                   Value="Delete goal" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background"
                            Value="#33FF4C4C" />
                    <Setter Property="Foreground"
                            Value="#FF6B6B" />
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- Убираем уродливое синее выделение ListBox -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30,20,30,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0"
              Margin="0,0,0,25">
            <TextBlock Text="Goals"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#FFFFFF"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="New goal"
                        Command="{Binding OpenAddGoalWindowCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,12,0" />

                <Button Content="Log out"
                        Command="{Binding LogoutCommand}"
                        Style="{StaticResource DangerButtonStyle}" />
            </StackPanel>
        </Grid>

        <!-- Goals List -->
        <ListBox ItemsSource="{Binding Goals}"
                 Grid.Row="1"
                 Background="Transparent"
                 BorderThickness="0"
                 HorizontalAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- Карточка цели -->
                    <Border Background="#212121"
                            CornerRadius="8"
                            Padding="20"
                            Margin="5,5,5,15"
                            MaxWidth="700"
                            HorizontalAlignment="Left">

                        <!-- Тень для карточки -->
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15"
                                              ShadowDepth="4"
                                              Opacity="0.15"
                                              Color="Black"
                                              Direction="270" />
                        </Border.Effect>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="450" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Текстовая часть -->
                            <StackPanel Grid.Column="0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="17"
                                           Foreground="#FFFFFF"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4" />

                                <TextBlock Text="{Binding Description}"
                                           Foreground="#A0A0A0"
                                           FontSize="14"
                                           LineHeight="20"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10" />

                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusTextConverter}}"
                                           Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                           FontSize="13"
                                           FontWeight="SemiBold" />
                            </StackPanel>

                            <!-- Кнопки управления (выровнены вправо) -->
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">

                                <!-- Play Icon -->
                                <Button Content="&#xE768;"
                                        Style="{StaticResource IconButtonStyle}"
                                        ToolTip="Start pomodoro session"
                                        Command="{Binding DataContext.StartSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />

                                <!-- Check Icon -->
                                <Button Content="&#xE73E;"
                                        Style="{StaticResource IconButtonStyle}"
                                        ToolTip="Mark as completed"
                                        Command="{Binding DataContext.CompleteGoalCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />

                                <!-- Edit Icon -->
                                <Button Content="&#xE70F;"
                                        Style="{StaticResource IconButtonStyle}"
                                        ToolTip="Edit goal"
                                        Command="{Binding DataContext.OpenEditGoalWindowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />

                                <!-- Trash Icon -->
                                <Button Content="&#xE74D;"
                                        Style="{StaticResource IconButtonStyle}"
                                        ToolTip="Delete goal"
                                        Command="{Binding DataContext.ArchiveGoalCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
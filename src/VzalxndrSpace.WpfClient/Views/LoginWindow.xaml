<Window x:Class="VzalxndrSpace.WpfClient.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VzalxndrSpace - Вход"
        Height="300"
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Stretch">
            <TextBlock Text="vzalxndr-space"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20" />
            <TextBlock Text="Enter admin password:"
                       Margin="0,0,0,5" />
            <PasswordBox x:Name="UserPasswordBox"
                         PasswordChanged="UserPasswordBox_PasswordChanged"
                         Margin="0,0,0,15"
                         Padding="5"
                         FontSize="16" />
            <Button Content="Login"
                    Command="{Binding LoginCommand}"
                    Height="35"
                    FontSize="16"
                    Background="#007ACC"
                    Foreground="White"
                    BorderThickness="0" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="VzalxndrSpace.WpfClient.Views.SessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="pomodoro-session"
        Height="320"
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#191919"
        FontFamily="Segoe UI"
        TextElement.Foreground="#E0E0E0"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <Style x:Key="TimerButtonStyle"
               TargetType="Button">
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="FontSize"
                    Value="15" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StartButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TimerButtonStyle}">
            <Setter Property="Background"
                    Value="#2EA043" />
            <Setter Property="Foreground"
                    Value="#FFFFFF" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#3FB950" />
                </Trigger>
                <Trigger Property="IsPressed"
                         Value="True">
                    <Setter Property="Background"
                            Value="#238636" />
                </Trigger>
                <Trigger Property="IsEnabled"
                         Value="False">
                    <Setter Property="Background"
                            Value="#2A2A2A" />
                    <Setter Property="Foreground"
                            Value="#555555" />
                    <Setter Property="Cursor"
                            Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StopButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TimerButtonStyle}">
            <Setter Property="Background"
                    Value="#33FF4C4C" />
            <Setter Property="Foreground"
                    Value="#FF6B6B" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#FF4C4C" />
                    <Setter Property="Foreground"
                            Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsPressed"
                         Value="True">
                    <Setter Property="Background"
                            Value="#D63A3A" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,15">
                <TextBlock Text="&#xE8F0;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           Foreground="#808080"
                           FontSize="16"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center" />

                <TextBlock Text="{Binding CurrentGoal.Title}"
                           Foreground="#A0A0A0"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock Text="{Binding TimeLeftDisplay}"
                       Foreground="#FFFFFF"
                       FontSize="76"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,35">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="0"
                                      Opacity="0.3"
                                      Color="#FFFFFF" />
                </TextBlock.Effect>
            </TextBlock>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button Content="Start session"
                        Command="{Binding StartTimerCommand}"
                        IsEnabled="{Binding IsStartButtonEnabled}"
                        Style="{StaticResource StartButtonStyle}"
                        Width="130"
                        Height="44"
                        Margin="0,0,15,0" />
                
                <Button Content="Stop session"
                        Command="{Binding StopSessionCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Style="{StaticResource StopButtonStyle}"
                        Width="130"
                        Height="44" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
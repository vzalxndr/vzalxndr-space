<Window x:Class="VzalxndrSpace.WpfClient.Views.EditGoalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit goal"
        Height="440"
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#191919"
        FontFamily="Segoe UI"
        TextElement.Foreground="#E0E0E0"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <Style x:Key="ModernTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Background"
                    Value="#0D0D0D" />
            <Setter Property="Foreground"
                    Value="#FFFFFF" />
            <Setter Property="BorderBrush"
                    Value="#303030" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="12,10" />
            <Setter Property="CaretBrush"
                    Value="#FFFFFF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="BorderBrush"
                                        Value="#555555" />
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#151515" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="BorderBrush"
                                        Value="#2EA043" />
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#0D0D0D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#2EA043" />
            <Setter Property="Foreground"
                    Value="#FFFFFF" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#3FB950" />
                </Trigger>
                <Trigger Property="IsPressed"
                         Value="True">
                    <Setter Property="Background"
                            Value="#238636" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="35,25,35,25">
        <StackPanel>
            <TextBlock Text="Edit goal"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#FFFFFF"
                       Margin="0,0,0,25" />

            <TextBlock Text="Title"
                       Foreground="#A0A0A0"
                       FontSize="14"
                       Margin="0,0,0,6" />

            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ModernTextBoxStyle}"
                     FontSize="15"
                     Margin="0,0,0,20" />

            <TextBlock Text="Description (optional)"
                       Foreground="#A0A0A0"
                       FontSize="14"
                       Margin="0,0,0,6" />

            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ModernTextBoxStyle}"
                     FontSize="15"
                     Height="90"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,15" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#FF6B6B"
                       FontSize="13"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,15" />

            <Button Content="Save changes"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Height="42"
                    FontSize="16" />
        </StackPanel>
    </Grid>
</Window>